{
  "name": "imFile",
  "version": "2.1.0",
  "description": "A full-featured download manager",
  "homepage": "https://github.com/imfile-io/imfile-desktop",
  "author": {
    "name": "Imfile",
    "email": "imfileapp@gmail.com"
  },
  "copyright": "Copyright© Imfile",
  "license": "MIT",
  "main": "./dist/electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/imfile-io/imfile-desktop.git"
  },
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "release": "node .electron-vue/build.js && electron-builder --publish onTagOrDraft",
    "build": "node .electron-vue/build.js && electron-builder",
    "build:win7": "pnpm up electron@22 && node .electron-vue/build.js && electron-builder --win --config.directories.output=release/win32/7",
    "build:win10": "node .electron-vue/build.js && electron-builder --win --config.directories.output=release/win32/10",
    "build:win:arm64": "node .electron-vue/build.js && electron-builder --win --arm64 --config.directories.output=release/win32/arm64",
    "build:applesilicon": "node .electron-vue/build.js && electron-builder --arm64 --mac",
    "build:github": "node .electron-vue/build.js",
    "build:dir": "node .electron-vue/build.js && electron-builder --dir",
    "build:clean": "cross-env BUILD_TARGET=clean node .electron-vue/build.js",
    "build:web": "cross-env BUILD_TARGET=web node .electron-vue/build.js",
    "dev": "node .electron-vue/dev-runner.js",
    "dev:renderer": "webpack serve --node-env development --hot --color --config .electron-vue/webpack.renderer.config.js --port 9080 --content-base app/dist",
    "lint": "eslint -f ./node_modules/eslint-friendly-formatter/index.js src",
    "lint:fix": "eslint -f ./node_modules/eslint-friendly-formatter/index.js --fix src",
    "pack": "pnpm run pack:main && pnpm run pack:renderer",
    "pack:main": "webpack --node-env production --progress --color --config .electron-vue/webpack.main.config.js",
    "pack:renderer": "webpack --node-env production --progress --color --config .electron-vue/webpack.renderer.config.js",
    "sync-goed2kd": "node scripts/sync-goed2kd.mjs",
    "sync-go-aria2": "node scripts/sync-go-aria2.mjs",
    "build:linux:dir": "node .electron-vue/build.js && electron-builder --linux dir --publish never",
    "flatpak": "node scripts/prepare-flatpak-stage.mjs && flatpak-builder --user --install --force-clean flatpak/.flatpak-build flatpak/io.github.imfile_io.imfile_desktop.yml",
    "postinstall": "electron-builder install-app-deps && pnpm run lint:fix"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@achingbrain/nat-port-mapper": "^4.0.5",
    "default-gateway": "^7.2.2",
    "node-fetch": "^2.7.0",
    "punycode": "2.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/plugin-transform-class-properties": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/register": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@bany/curl-to-json": "^1.2.10",
    "@electron/notarize": "^3.1.1",
    "@electron/osx-sign": "^2.5.0",
    "@electron/remote": "^2.1.3",
    "@element-plus/icons-vue": "^2.3.2",
    "@motrix/multispinner": "^0.2.4",
    "@tailwindcss/postcss": "^4.3.2",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/eslint-config-standard": "^9.0.1",
    "ajv": "^8.20.0",
    "axios": "^1.18.1",
    "babel-loader": "^10.1.1",
    "bittorrent-peerid": "^2.0.2",
    "blob-util": "^2.0.2",
    "cfonts": "^3.3.1",
    "chalk": "4.1.2",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "del": "^8.0.1",
    "electron": "42.6.1",
    "electron-builder": "^26.15.3",
    "electron-devtools-installer": "^4.0.0",
    "electron-is": "^3.0.0",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "element-plus": "^2.14.2",
    "eslint": "^9.39.4",
    "eslint-friendly-formatter": "^4.0.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-webpack-plugin": "^6.0.0",
    "file-loader": "^6.2.0",
    "globals": "^17.7.0",
    "html-webpack-plugin": "^5.6.7",
    "i18next": "^26.3.5",
    "lodash": "^4.18.1",
    "mini-css-extract-plugin": "2.10.2",
    "node-loader": "^2.1.0",
    "normalize.css": "^8.0.1",
    "parse-torrent": "^11.0.21",
    "postcss": "^8.5.16",
    "postcss-loader": "^8.2.1",
    "randomatic": "^3.1.1",
    "sass": "1.101.7",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.3.2",
    "terser-webpack-plugin": "^5.6.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vue": "^3.5.39",
    "vue-eslint-parser": "^10.4.1",
    "vue-i18n": "^11.4.6",
    "vue-loader": "^17.4.2",
    "vue-router": "^5.1.0",
    "vue-style-loader": "^4.1.3",
    "vuex": "^4.1.0",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0",
    "webpack-hot-middleware": "^2.26.1",
    "webpack-merge": "^6.0.1",
    "worker-loader": "^3.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ],
    "overrides": {
      "punycode": "2.3.1"
    }
  }
}
